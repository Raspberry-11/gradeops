# ─────────────────────────────────────────────
# GradeOps Environment Variables
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values
# 3. NEVER commit .env to git — it's in .gitignore
# ─────────────────────────────────────────────

# ── App ───────────────────────────────────────
APP_NAME=GradeOps
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────
# For Docker Compose local dev, use the defaults below as-is.
DATABASE_URL=postgresql+asyncpg://gradeops:gradeops@localhost:5432/gradeops

# ── Security ──────────────────────────────────
# Generate a strong secret:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ── OCR Backend ───────────────────────────────
# gemini  → Google Gemini Vision API (no GPU, recommended)
# groq    → Groq Vision API (fast, recommended)
# mock    → Dummy text for local testing without any API key
OCR_BACKEND=groq
OCR_DEVICE=cpu
OCR_DPI=200
OCR_CROP_DIR=./crops
# Change to gemini-1.5-pro for harder/messier handwriting
GEMINI_OCR_MODEL=gemini-2.0-flash

# ── Grading LLM ───────────────────────────────
# groq | gemini | openai | anthropic | together | mock
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMP=0.0

# ── API Keys ──────────────────────────────────
# Get your Gemini key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
TOGETHER_API_KEY=

# ── Plagiarism ────────────────────────────────
PLAGIARISM_THRESHOLD=0.82
PLAGIARISM_EMBEDDINGS=false
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Storage ───────────────────────────────────
STORAGE_BACKEND=local
STORAGE_DATA_DIR=./gradeops_data

# ── CORS ──────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
