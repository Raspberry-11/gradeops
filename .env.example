# ─────────────────────────────────────────────
# GradeOps — Root Environment Variables
# Used by docker-compose.yml to inject into containers.
#
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your API keys below
# 3. Run:  docker compose up --build
# ─────────────────────────────────────────────

# ── AI / OCR ──────────────────────────────────
# OCR_BACKEND options: gemini | groq | mock
OCR_BACKEND=groq

# LLM_PROVIDER options: groq | gemini | openai | anthropic | together | mock
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# ── API Keys ──────────────────────────────────
# At least one key is required depending on your chosen backends.
# Groq  → https://console.groq.com/keys
# Gemini → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
